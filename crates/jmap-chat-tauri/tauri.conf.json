{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jmap-chat-tauri",
  "identifier": "com.jmapchat.tauri",
  "build": {
    "frontendDist": "./dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/32x32.png", "icons/128x128.png"]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JMAP Chat",
        "width": 800,
        "height": 600
      }
    ],
    "withGlobalTauri": false
  }
}
